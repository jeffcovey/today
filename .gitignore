# =============================================================================
# Environment & Secrets
# =============================================================================
# Environment files (created by plugin configuration)
.env
.env.keys

# =============================================================================
# User Configuration (copy from *.example files)
# =============================================================================
config.toml

# =============================================================================
# Credentials & Keys
# =============================================================================
*.pem
*.key
*credentials*.json
*secrets*.json
.inbox-api-key
.resilio-password
Resilio Sync.btskey

# =============================================================================
# Data & Cache
# =============================================================================
.data/
.last-dep-check

# =============================================================================
# Vault (synced separately, top-level only)
# =============================================================================
/vault
/vault/

# =============================================================================
# Build & Dependencies
# =============================================================================
node_modules/
dist/
__pycache__/
*.pyc
*.pyo

# =============================================================================
# Editor & IDE
# =============================================================================
.vscode-cli/
.claude/
*.code-workspace

# =============================================================================
# Git Worktrees
# =============================================================================
.worktrees/

# =============================================================================
# DevContainer Local Config
# =============================================================================
.devcontainer/mounts.local
.devcontainer/personal-setup.sh
.devcontainer/docker-compose.override.yml
# Root-level docker-compose override is auto-generated from
# .devcontainer/mounts.local by generate-compose-override.sh and points
# the local-deployment compose services at the user's real vault.
/docker-compose.override.yml

# =============================================================================
# OS Files
# =============================================================================
.DS_Store
*.log

# =============================================================================
# Runtime (container/server specific)
# =============================================================================
.config/
.local/
.npm/
backups/

# =============================================================================
# Internal/Experimental (not ready for public release)
# =============================================================================
.internal/
coverage/
