  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "lefthook": "^2.1.6",
