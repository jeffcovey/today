{
  "name": "today",
  "version": "1.0.0",
  "description": "A personal command center for reviewing inputs, managing plans and dreams, and deciding what to do each day",
  "bin": {
    "email": "./bin/email"
  },
  "scripts": {
    "prepare": "[ -f node_modules/.bin/lefthook ] && lefthook install || true",
    "test": "NODE_OPTIONS='--experimental-vm-modules' npx jest",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' npx jest --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' npx jest --coverage",
    "lint:md": "markdownlint-cli2 '**/*.md' '!node_modules/**'",
    "lint:md:fix": "markdownlint-cli2 --fix '**/*.md' '!node_modules/**'",
    "lint:vault": "markdownlint-cli2 'vault/**/*.md'",
    "lint:vault:fix": "markdownlint-cli2 --fix 'vault/**/*.md'",
    "lint": "npm run lint:md"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/openai": "^3.0.53",
    "@anthropic-ai/sdk": "^0.90.0",
    "@clack/prompts": "^1.2.0",
    "@date-fns/tz": "^1.4.1",
    "@dotenvx/dotenvx": "^1.61.1",
    "@inkjs/ui": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.168",
    "better-sqlite3": "^12.9.0",
    "better-sqlite3-session-store": "^0.1.0",
    "canvas": "^3.2.3",
    "chart.js": "^4.5.1",
    "cheerio": "^1.2.0",
    "chokidar": "^5.0.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.2",
    "countries-and-timezones": "^3.9.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.18.2",
    "googleapis": "^171.4.0",
    "highlight.js": "^11.11.1",
    "htm": "^3.1.1",
    "imapflow": "^1.3.2",
    "ink": "^7.0.1",
    "js-yaml": "^4.1.0",
    "mailparser": "^3.9.6",
    "markdownlint": "^0.40.0",
    "marked": "^18.0.2",
    "marked-gfm-heading-id": "^4.1.3",
    "marked-highlight": "^2.2.3",
    "moment": "^2.30.1",
