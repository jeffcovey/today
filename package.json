  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "lefthook": "^2.1.9",
    "markdownlint-cli2": "^0.23.0"
